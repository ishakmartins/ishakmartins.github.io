---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import figmaLogo from '../assets/logos/figma.svg';
import framerLogo from '../assets/logos/framer.svg';
import shopifyLogo from '../assets/logos/shopify.svg';
import webflowLogo from '../assets/logos/webflow.svg';

const tools = [
	{ name: 'Figma', logo: figmaLogo, tone: 'light' },
	{ name: 'Framer', logo: framerLogo, tone: 'dark' },
	{ name: 'Shopify', logo: shopifyLogo, tone: 'light' },
	{ name: 'Webflow', logo: webflowLogo, tone: 'light' },
];
---

<Layout
	title="Units | Lokanetra"
	description="Units page for Lokanetra."
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero">
				<p class="eyebrow"><a href="open.lokanetra.dev">open.lokanetra.dev</a></p>
				<h1 class="display-title">Open Lokanetra Products (OLP)</h1>
				<div class="hero-subgrid">
					<p class="hero-text">
						
					</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Web-apps</p>
				</div>
				<div class="story-block">
					<p>Coming soon</p>
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">Datasets</p>
				</div>
				<div class="story-block">
					<p>Coming soon.</p>	
				</div>
			</section>

			<section class="editorial-section">
				<div class="section-rail">
					<p class="section-kicker">GitHub Repo/ Source Code</p>
				</div>
				<div class="story-block">
					<p>Coming soon.</p>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.section-kicker {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.hero {
		padding: 6rem 0 4rem;
	}

	.eyebrow,
	.section-kicker {
		margin: 0;
		color: var(--muted-foreground);
		font-style: normal;
	}

	.hero-subgrid {
		display: grid;
		grid-template-columns: 1fr;
		margin-top: 1.75rem;
	}

	.hero-text,
	.story-block p {
		font-size: 1.08rem;
		line-height: 1.7;
		margin: 0;
	}

	.editorial-section {
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		gap: 2rem;
		padding: 2.5rem 0;
		border-top: 1px solid var(--border);
	}

	.section-rail {
		align-self: start;
	}

	.story-block {
		display: grid;
		gap: 1rem;
		max-width: 52rem;
	}

	.story-block strong {
		color: var(--foreground);
	}

	.tools-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		max-width: 44rem;
	}

	.tool-card {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		padding: 1rem 1.05rem;
		border: 1px solid var(--border);
		border-radius: 1.15rem;
		background: var(--card);
	}

	.tool-mark {
		width: 3rem;
		height: 3rem;
		flex: 0 0 3rem;
		display: grid;
		place-items: center;
		border-radius: 0.9rem;
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--muted) 90%, var(--card) 10%) 0%,
			color-mix(in srgb, var(--border) 55%, var(--card) 45%) 100%
		);
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--background) 12%);
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		color: var(--foreground);
	}

	.tool-mark-dark {
		background: #0d1014;
		border-color: #0d1014;
	}

	.tool-logo {
		width: 1.55rem;
		height: 1.55rem;
		display: block;
		object-fit: contain;
	}

	.tool-name {
		margin: 0;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	@media (max-width: 980px) {
		.hero-subgrid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 3rem;
		}

		.editorial-section {
			grid-template-columns: 1fr;
		}

		.hero-text,
		.story-block p {
			font-size: 1.05rem;
		}

		.tools-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
